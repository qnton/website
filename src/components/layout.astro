---
import "@/styles/globals.css";
import { ClientRouter, fade } from "astro:transitions";

const pageFade = fade({ duration: "0.55s" });

interface Props {
  title: string;
  description: string;
  ogType?: string;
  robots?: string;
  noStructuredData?: boolean;
}

const {
  title,
  description,
  ogType = "website",
  robots,
  noStructuredData = false,
} = Astro.props;

const siteConfig = import.meta.env.SITE ?? "https://qnt.one/";
const origin = new URL(siteConfig).origin;
const path =
  Astro.url.pathname.length > 1 ? Astro.url.pathname.replace(/\/$/, "") : "";
const canonicalUrl = new URL(path || "/", `${origin}/`).href;

const structuredDescription = "Contact information for qnt.one.";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${origin}/#website`,
      url: origin,
      name: "qnt.one",
      description: structuredDescription,
      inLanguage: "en",
    },
  ],
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      content="width=device-width,initial-scale=1"
      name="viewport"
    />

    <title>{title}</title>
    <meta
      content={description}
      name="description"
    />
    {
      robots && (
        <meta
          content={robots}
          name="robots"
        />
      )
    }
    <meta
      content="#000000"
      name="theme-color"
    />

    <link
      rel="canonical"
      href={canonicalUrl}
    />

    <meta
      content={ogType}
      property="og:type"
    />
    <meta
      content={title}
      property="og:title"
    />
    <meta
      content={description}
      property="og:description"
    />
    <meta
      content={canonicalUrl}
      property="og:url"
    />

    {
      !noStructuredData && (
        <script
          set:html={JSON.stringify(jsonLd)}
          type="application/ld+json"
        />
      )
    }
    <ClientRouter />
  </head>
  <body>
    <div
      transition:animate={pageFade}
      transition:name="page"
    >
      <slot />
    </div>
  </body></html
>
