---
import "@/styles/globals.css";
import { ClientRouter } from "astro:transitions";

interface Alternate {
  hreflang: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  lang?: string;
  /** Absolute URL for Open Graph / Twitter image */
  image?: string;
  ogType?: string;
  robots?: string;
  /** Skip JSON-LD (e.g. 404) */
  noStructuredData?: boolean;
  /** hreflang alternates (e.g. EN ↔ DE legal) */
  alternates?: Alternate[];
  /** x-default alternate href */
  xDefaultHref?: string;
}

const {
  title,
  description,
  lang = "en",
  image: imageProp,
  ogType = "website",
  robots,
  noStructuredData = false,
  alternates,
  xDefaultHref,
} = Astro.props;

const siteConfig = import.meta.env.SITE ?? "https://qnt.one/";
const origin = new URL(siteConfig).origin;
const path =
  Astro.url.pathname.length > 1 ? Astro.url.pathname.replace(/\/$/, "") : "";
const canonicalUrl = new URL(path || "/", `${origin}/`).href;
const defaultOgImage = `${origin}/images/pfp.jpg`;
const ogImage = imageProp ?? defaultOgImage;
const ogImageSecure = ogImage.startsWith("http")
  ? ogImage
  : new URL(ogImage.replace(/^\//, ""), `${origin}/`).href;

const structuredDescription =
  "Senior designer and engineer building exceptional digital products. Web development, design, and digital transformation.";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${origin}/#website`,
      url: origin,
      name: "Anton Werschinin",
      description: structuredDescription,
      inLanguage: ["en", "de"],
      publisher: { "@id": `${origin}/#person` },
    },
    {
      "@type": "Person",
      "@id": `${origin}/#person`,
      name: "Anton Werschinin",
      givenName: "Anton",
      familyName: "Werschinin",
      email: "hello@qnt.one",
      url: origin,
      image: `${origin}/images/pfp.jpg`,
      jobTitle: "Designer & Engineer",
      knowsLanguage: ["de-DE", "en-US"],
      sameAs: [
        "https://www.linkedin.com/in/qnton",
        "https://github.com/qnton",
        "https://dev.to/qnton",
      ],
      address: {
        "@type": "PostalAddress",
        streetAddress: "Hinterm Wall 28",
        addressLocality: "Cloppenburg",
        postalCode: "49661",
        addressCountry: "DE",
      },
    },
    {
      "@type": "ProfessionalService",
      "@id": `${origin}/#professionalService`,
      name: "qnton",
      url: origin,
      description: structuredDescription,
      address: {
        "@type": "PostalAddress",
        streetAddress: "Hinterm Wall 28",
        addressLocality: "Cloppenburg",
        postalCode: "49661",
        addressCountry: "DE",
      },
      areaServed: {
        "@type": "Country",
        name: "DE",
      },
      founder: { "@id": `${origin}/#person` },
    },
  ],
};
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta
      content="width=device-width,initial-scale=1"
      name="viewport"
    />

    <title>{title}</title>
    <meta
      content={description}
      name="description"
    />
    {
      robots && (
        <meta
          content={robots}
          name="robots"
        />
      )
    }
    <meta
      content="#000000"
      name="theme-color"
    />

    <link
      rel="canonical"
      href={canonicalUrl}
    />

    <meta
      content={ogType}
      property="og:type"
    />
    <meta
      content={title}
      property="og:title"
    />
    <meta
      content={description}
      property="og:description"
    />
    <meta
      content={canonicalUrl}
      property="og:url"
    />
    <meta
      content="Anton Werschinin"
      property="og:site_name"
    />
    <meta
      content={ogImageSecure}
      property="og:image"
    />
    <meta
      content="image/jpeg"
      property="og:image:type"
    />
    <meta
      content="512"
      property="og:image:width"
    />
    <meta
      content="512"
      property="og:image:height"
    />
    <meta
      content={lang === "de" ? "de_DE" : "en_US"}
      property="og:locale"
    />

    <meta
      content="summary_large_image"
      name="twitter:card"
    />
    <meta
      content={title}
      name="twitter:title"
    />
    <meta
      content={description}
      name="twitter:description"
    />
    <meta
      content={ogImageSecure}
      name="twitter:image"
    />

    <link
      href="/favicon.ico"
      rel="icon"
      type="image/x-icon"
    />
    <link
      href="/images/apple-touch-icon-ipad-retina-152x152.png"
      rel="apple-touch-icon"
      sizes="152x152"
    />
    <link
      href="/images/apple-touch-icon-iphone-retina-120x120.png"
      rel="apple-touch-icon"
      sizes="120x120"
    />
    <link
      href="/images/apple-touch-icon-ipad-76x76.png"
      rel="apple-touch-icon"
      sizes="76x76"
    />
    <link
      href="/images/apple-touch-icon-iphone-60x60.png"
      rel="apple-touch-icon"
      sizes="60x60"
    />
    {
      !noStructuredData && (
        <script
          set:html={JSON.stringify(jsonLd)}
          type="application/ld+json"
        />
      )
    }
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
    />
    {
      alternates?.map((a) => (
        <link
          rel="alternate"
          hreflang={a.hreflang}
          href={a.href}
        />
      ))
    }
    {
      xDefaultHref && (
        <link
          rel="alternate"
          hreflang="x-default"
          href={xDefaultHref}
        />
      )
    }
    <ClientRouter />
  </head>
  <body>
    <div>
      <slot />
    </div>
    <script>
      import "@/libs/scripts.js";
    </script>
  </body></html
>
