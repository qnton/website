---
import "@/styles/globals.css";

import instrumentSerifLatin from "@/styles/fonts/instrument-serif-400-normal-latin.woff2?url";
import satoshiLight from "@/styles/fonts/Satoshi-Light.woff2?url";
import satoshiRegular from "@/styles/fonts/Satoshi-Regular.woff2?url";
import satoshiMedium from "@/styles/fonts/Satoshi-Medium.woff2?url";

interface Props {
  title: string;
  description: string;
  ogType?: string;
  robots?: string;
  noStructuredData?: boolean;
}

const {
  title,
  description,
  ogType = "website",
  robots,
  noStructuredData = false,
} = Astro.props;

const siteConfig = import.meta.env.SITE ?? "https://qnt.one/";
const origin = new URL(siteConfig).origin;
const path =
  Astro.url.pathname.length > 1 ? Astro.url.pathname.replace(/\/$/, "") : "";
const canonicalUrl = new URL(path || "/", `${origin}/`).href;
const ogImageUrl = new URL("/og.png", `${origin}/`).href;

const OG_IMAGE_WIDTH = 1200;
const OG_IMAGE_HEIGHT = 630;

const criticalFonts = [
  { href: instrumentSerifLatin },
  { href: satoshiRegular },
  { href: satoshiLight },
  { href: satoshiMedium },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      content="width=device-width,initial-scale=1"
      name="viewport"
    />

    {
      criticalFonts.map(({ href }) => (
        <link
          rel="preload"
          href={href}
          as="font"
          type="font/woff2"
          crossorigin="anonymous"
        />
      ))
    }

    <title>{title}</title>
    <meta
      content={description}
      name="description"
    />
    {
      robots && (
        <meta
          content={robots}
          name="robots"
        />
      )
    }
    <meta
      content="#000000"
      name="theme-color"
    />

    <link
      rel="canonical"
      href={canonicalUrl}
    />

    <meta
      content={ogType}
      property="og:type"
    />
    <meta
      content={title}
      property="og:title"
    />
    <meta
      content={description}
      property="og:description"
    />
    <meta
      content={canonicalUrl}
      property="og:url"
    />
    <meta
      content="qnt.one"
      property="og:site_name"
    />
    <meta
      content="en_US"
      property="og:locale"
    />
    <meta
      content={ogImageUrl}
      property="og:image"
    />
    <meta
      content={String(OG_IMAGE_WIDTH)}
      property="og:image:width"
    />
    <meta
      content={String(OG_IMAGE_HEIGHT)}
      property="og:image:height"
    />
    <meta
      content="image/png"
      property="og:image:type"
    />
    <meta
      content={title}
      property="og:image:alt"
    />

    <meta
      content="summary_large_image"
      name="twitter:card"
    />
    <meta
      content="@qnton"
      name="twitter:creator"
    />
    <meta
      content={title}
      name="twitter:title"
    />
    <meta
      content={description}
      name="twitter:description"
    />
    <meta
      content={ogImageUrl}
      name="twitter:image"
    />

    {
      !noStructuredData && (
        <script
          src="/schema.json"
          type="application/ld+json"
        />
      )
    }
  </head>
  <body>
    <slot />
  </body>
</html>
