---
import "@/styles/globals.css";
import { ClientRouter, fade } from "astro:transitions";

const pageFade = fade({ duration: "0.55s" });

interface Props {
  title: string;
  description: string;
  ogType?: string;
  robots?: string;
  noStructuredData?: boolean;
}

const {
  title,
  description,
  ogType = "website",
  robots,
  noStructuredData = false,
} = Astro.props;

const siteConfig = import.meta.env.SITE ?? "https://qnt.one/";
const origin = new URL(siteConfig).origin;
const path =
  Astro.url.pathname.length > 1 ? Astro.url.pathname.replace(/\/$/, "") : "";
const canonicalUrl = new URL(path || "/", `${origin}/`).href;
const ogImageUrl = new URL("/og.png", `${origin}/`).href;

const personId = `${origin}/#person`;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": personId,
      name: "Anton Werschinin",
      alternateName: ["qnton", "qnt.one"],
      url: `${origin}/`,
      email: "hello@qnt.one",
    },
    {
      "@type": "WebSite",
      "@id": `${origin}/#website`,
      url: origin,
      name: "qnt.one",
      description,
      inLanguage: "en",
      publisher: { "@id": personId },
    },
  ],
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      content="width=device-width,initial-scale=1"
      name="viewport"
    />

    <title>{title}</title>
    <meta
      content={description}
      name="description"
    />
    {
      robots && (
        <meta
          content={robots}
          name="robots"
        />
      )
    }
    <meta
      content="#000000"
      name="theme-color"
    />

    <link
      rel="canonical"
      href={canonicalUrl}
    />

    <meta
      content={ogType}
      property="og:type"
    />
    <meta
      content={title}
      property="og:title"
    />
    <meta
      content={description}
      property="og:description"
    />
    <meta
      content={canonicalUrl}
      property="og:url"
    />
    <meta
      content="qnt.one"
      property="og:site_name"
    />
    <meta
      content="en_US"
      property="og:locale"
    />
    <meta
      content={ogImageUrl}
      property="og:image"
    />
    <meta
      content={title}
      property="og:image:alt"
    />

    <meta
      content="summary_large_image"
      name="twitter:card"
    />
    <meta
      content={title}
      name="twitter:title"
    />
    <meta
      content={description}
      name="twitter:description"
    />
    <meta
      content={ogImageUrl}
      name="twitter:image"
    />

    {
      !noStructuredData && (
        <script
          set:html={JSON.stringify(jsonLd)}
          type="application/ld+json"
        />
      )
    }
    <ClientRouter />
  </head>
  <body>
    <div
      transition:animate={pageFade}
      transition:name="page"
    >
      <slot />
    </div>
  </body>
</html>
