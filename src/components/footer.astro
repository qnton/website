---
import { merge } from "@/libs/merge";

const { class: className } = Astro.props;

const year = new Date().getFullYear();
---

<footer
  class={merge("footer-section", className)}
  data-reveal
  id="contact"
>
  <div class="section__inner">
    <!-- Section head -->
    <header class="section-head">
      <span class="section-head__label">Get in touch</span>
      <span class="section-head__meta">Available · {year}</span>
    </header>

    <!-- Section title -->
    <h2 class="section-title">
      Work <em>with</em> me.
    </h2>

    <!-- Description -->
    <p
      class="tone-muted font-satoshi-light m-0 mt-6 max-w-lg text-base leading-relaxed md:text-lg"
    >
      A project in mind? I take on a small, deliberate number of clients each
      year so every engagement stays focused, considered, and high-quality.
    </p>

    <!-- Mailto CTA -->
    <div class="mt-14 lg:mt-20">
      <address
        class="not-italic"
        data-mailto-token="ocknvq<jgnnqBspr0qpg>"
        data-mailto-vector="2"
      >
      </address>
      <a
        href="mailto:hello@qnt.one"
        class="footer-mailto"
      >
        hello@qnt.one
        <span
          class="footer-mailto__arrow"
          aria-hidden="true"
        >
          <svg
            width="28"
            height="28"
            viewBox="0 0 28 28"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M7 21L21 7M21 7H10M21 7v11"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path>
          </svg>
        </span>
      </a>
    </div>

    <!-- Meta row: socials + copyright (micro-caps, framed by hairline) -->
    <div class="footer-meta">
      <nav
        class="footer-meta-nav"
        id="github"
        aria-label="Profiles and external links"
      >
        <a
          class="footer-meta-link"
          href="https://github.com/qnton"
          rel="noopener noreferrer"
          target="_blank"
        >
          GitHub
        </a>
        <a
          class="footer-meta-link"
          href="https://linkedin.com/in/qnton"
          rel="noopener noreferrer"
          target="_blank"
        >
          LinkedIn
        </a>
        <a
          class="footer-meta-link"
          href="/legal"
        >
          Legal &amp; Privacy
        </a>
      </nav>

      <p class="footer-copy">&copy; {year} · Anton Werschinin</p>
    </div>
  </div>
</footer>
