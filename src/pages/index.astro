---
import Layout from "@/components/layout.astro";
---

<Layout
  description="Have a project in mind? Get in touch for focused, high-quality collaboration."
  title="qnt.one"
>
  <main
    class="min-h-dvh bg-black px-[clamp(1.5rem,6vw,4rem)] pt-[clamp(3rem,12vh,8rem)] pb-16 text-left"
    id="main-content"
  >
    <div class="max-w-[36rem]">
      <p
        class="font-satoshi-medium m-0 text-[0.6875rem] tracking-[0.22em] text-[oklch(58%_0_0)] uppercase"
      >
        Get in touch
      </p>

      <h1
        class="font-instrument-serif m-0 mt-5 text-[clamp(2.75rem,8vw,4.25rem)] leading-[1.05] font-normal tracking-[-0.02em] text-white"
      >
        Work with me
      </h1>

      <p
        class="tone-muted font-satoshi-light m-0 mt-6 max-w-lg text-base leading-relaxed md:text-lg"
      >
        Have a project in mind? I take on a select number of clients each year
        to ensure focused, high-quality collaboration.
      </p>

      <div class="mt-12 md:mt-16">
        <a
          class="font-instrument-serif inline-flex max-w-full items-baseline gap-2 border-b border-white pb-1 text-[clamp(1.75rem,5vw,2.75rem)] leading-none tracking-[-0.02em] text-white no-underline transition-opacity hover:opacity-85"
          href="mailto:hello@qnt.one"
        >
          <span class="min-w-0 break-all">hello@qnt.one</span>
          <span
            class="inline-flex shrink-0 translate-y-[0.08em] self-center"
            aria-hidden="true"
          >
            <svg
              class="size-[0.55em] md:size-[0.5em]"
              fill="none"
              height="24"
              viewBox="0 0 24 24"
              width="24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M6 18L18 6M18 6H9M18 6V15"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.25"
              ></path>
            </svg>
          </span>
        </a>
      </div>
    </div>
  </main>
</Layout>
