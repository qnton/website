---
import Layout from "@/components/layout.astro";
import Footer from "@/components/footer.astro";

/* Selected work — re-enable when you have case studies to show
const projects = [
  {
    slug: "global-scale-infrastructure",
    title: "Global Scale Infrastructure",
    category: "Engineering",
    tile: "tile-infrastructure",
    year: "2024",
    delay: "0",
  },
  {
    slug: "premium-ecommerce-ux",
    title: "Premium E-commerce UX",
    category: "Design & Development",
    tile: "tile-ecommerce",
    year: "2024",
    delay: "100",
  },
  {
    slug: "intelligent-data-platform",
    title: "Intelligent Data Platform",
    category: "Engineering",
    tile: "tile-data-platform",
    year: "2023",
    delay: "200",
  },
  {
    slug: "brand-identity-system",
    title: "Brand Identity System",
    category: "Design",
    tile: "tile-brand-identity",
    year: "2023",
    delay: "300",
  },
];
*/

const services = [
  {
    number: "01",
    title: "Web Development",
    description:
      "Performance-driven applications built with modern stacks. From architecture to deployment, delivered with engineering rigour and attention to every millisecond.",
  },
  {
    number: "02",
    title: "Design",
    description:
      "Brand systems, interface design, and visual identity that communicate authority. Rooted in craft, built to endure, refined until nothing remains to remove.",
  },
  {
    number: "03",
    title: "Digital Transformation",
    description:
      "Strategic modernisation of legacy systems and digital workflows. Clear roadmaps, measurable outcomes, and technical consulting across the full stack.",
  },
];
---

<Layout
  description="Senior Designer & Engineer with a decade of experience building exceptional digital products."
  title="Anton Werschinin — Designer & Engineer"
>
  <main
    class="bg-black"
    id="main-content"
  >
    <!-- ─── HERO ─────────────────────────────────────────────── -->
    <section
      class="hero-section relative flex min-h-[100dvh] flex-col items-stretch justify-center overflow-hidden"
    >
      <!-- Name block -->
      <div
        class="relative z-10 flex flex-col px-6 pt-16 pb-24 md:px-10 md:pb-28 lg:px-14"
      >
        <h1 class="font-instrument-serif m-0 leading-[0.88] tracking-[-0.04em]">
          <span
            class="hero-name hero-reveal tone-primary block leading-[0.88] tracking-[-0.04em]"
            style="--reveal-delay: 200ms;"
          >
            Anton
          </span>

          <span
            class="hero-divider hero-reveal block"
            style="--reveal-delay: 400ms;"
            aria-hidden="true"
          >
            <span class="hero-divider-label"
              >Senior Designer &amp; Engineer</span
            >
            <span class="hero-divider-line"></span>
            <span class="hero-divider-label">10 years of craft</span>
          </span>

          <span
            class="hero-name hero-name-second hero-reveal tone-muted block leading-[0.88] tracking-[-0.04em]"
            style="--reveal-delay: 550ms;"
          >
            Werschinin
          </span>
        </h1>
      </div>

      <!-- Bottom bar -->
      <div
        class="absolute right-0 bottom-0 left-0 z-10 flex flex-row items-end justify-between px-6 pb-10 md:px-10 lg:px-14"
      >
        <p
          class="hero-reveal font-satoshi-light tone-quiet m-0 max-w-sm text-sm leading-relaxed md:text-base"
          style="--reveal-delay: 800ms;"
        >
          Engineering precision, design intention,<br />and products that still
          make sense.
        </p>
      </div>
    </section>

    {
      /*
    ─── SELECTED WORK (commented out — nothing to show yet; uncomment + restore `projects` in frontmatter)
    Use data-reveal-stagger on max-w-5xl, data-reveal-item + --reveal-index on header and tiles (see Core Services).
    <section
      class="scroll-mt-8 px-6 py-24 lg:scroll-mt-12 lg:py-36"
      id="selected-work"
    >
      <div class="mx-auto max-w-5xl" data-reveal-stagger>
        <div
          class="border-subtle mb-12 flex items-end justify-between border-b pb-8 lg:mb-16"
          data-reveal-item
          style={{ "--reveal-index": 0 }}
        >
          <div class="flex flex-col gap-3">
            <span class="section-label">Portfolio</span>
            <h2
              class="tone-primary font-instrument-serif m-0 text-3xl leading-none md:text-4xl lg:text-5xl"
            >
              Selected Work
            </h2>
          </div>
          <span class="tone-quiet font-satoshi-light hidden text-sm md:block"
            >2023 – 2024</span
          >
        </div>

        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:gap-6">
          {
            projects.map((project, i) => (
              <article
                class={`project-tile project-tile--static group relative overflow-hidden rounded-sm`}
                data-reveal-item
                style={{ "--reveal-index": i + 1 }}
                aria-labelledby={`tile-title-${project.slug}`}
              >
                <div
                  class={`${project.tile} aspect-[4/3] w-full lg:aspect-[3/2]`}
                  role="presentation"
                />

                <div
                  class="tile-overlay pointer-events-none absolute inset-0 transition-all duration-400"
                  style="background: linear-gradient(to top, oklch(0% 0 0 / 0.85) 0%, oklch(0% 0 0 / 0.35) 50%, oklch(0% 0 0 / 0.05) 100%);"
                />

                <div class="absolute inset-0 flex flex-col justify-between p-6 lg:p-8">
                  <div class="flex items-start justify-between gap-3">
                    <span class="section-label">{project.category}</span>
                    <div class="shrink-0 text-right">
                      <span class="tone-muted font-satoshi-light block text-xs tabular-nums">
                        {project.year}
                      </span>
                      <span class="tone-quiet font-satoshi-light mt-1 block text-[10px] uppercase tracking-wider">
                        Case study soon
                      </span>
                    </div>
                  </div>
                  <div class="flex items-end justify-between gap-4">
                    <h3
                      class="tone-primary font-instrument-serif m-0 max-w-[80%] text-xl leading-snug md:text-2xl lg:text-3xl"
                      id={`tile-title-${project.slug}`}
                    >
                      {project.title}
                    </h3>
                    <div
                      class="tile-arrow tone-muted"
                      aria-hidden="true"
                    >
                      <svg
                        width="20"
                        height="20"
                        viewBox="0 0 20 20"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <path
                          d="M5 15L15 5M15 5H7M15 5v8"
                          stroke="currentColor"
                          stroke-width="1.5"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        />
                      </svg>
                    </div>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>
    */
    }

    <!-- ─── CORE SERVICES ─────────────────────────────────────── -->
    <section class="border-subtle border-t px-6 py-24 lg:py-36">
      <div
        class="mx-auto max-w-5xl"
        data-reveal-stagger
      >
        <!-- Section header (reveals first in stagger) -->
        <div
          class="mb-16 flex flex-col gap-3 lg:mb-20"
          data-reveal-item
          style={{ "--reveal-index": 0 }}
        >
          <span class="section-label">What I do</span>
          <h2
            class="tone-primary font-instrument-serif m-0 text-3xl leading-none md:text-4xl lg:text-5xl"
          >
            Core Services
          </h2>
        </div>

        <!-- Services -->
        <div class="border-subtle flex flex-col divide-y">
          {
            services.map((service, i) => (
              <div
                class="service-row group grid grid-cols-1 gap-6 py-12 md:grid-cols-[120px_1fr_1fr] md:gap-8 md:py-10 lg:py-14"
                data-reveal-item
                style={{ "--reveal-index": i + 1 }}
              >
                <div class="service-number font-instrument-serif">
                  {service.number}
                </div>
                <h3 class="tone-primary font-satoshi-medium m-0 self-start text-xl md:text-2xl">
                  {service.title}
                </h3>
                <p class="tone-muted font-satoshi-light m-0 self-start text-base leading-relaxed md:text-lg">
                  {service.description}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ─── FOOTER ─────────────────────────────────────────────── -->
    <Footer />
  </main>
</Layout>
