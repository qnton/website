---
import { homeDescription } from "@/data/site";
import Layout from "@/components/layout.astro";
---

<Layout
  description={homeDescription}
  title="Anton Werschinin — qnt.one"
>
  <main
    class="relative flex min-h-dvh flex-col bg-[oklch(8%_0.01_75)] px-[clamp(1.5rem,6vw,4rem)] pt-[clamp(3rem,12vh,8rem)] pb-10 text-left selection:bg-[oklch(78%_0.07_85)]/20"
    id="main-content"
  >
    <div class="max-w-[36rem] flex-1">
      <p
        class="reveal font-satoshi-medium m-0 text-[0.6875rem] tracking-[0.26em] text-[oklch(58%_0.015_80)] uppercase"
        style="--i: 0"
      >
        Get in touch
      </p>

      <h1
        class="reveal font-instrument-serif m-0 mt-5 text-[clamp(2.75rem,8vw,4.25rem)] leading-[1.05] font-normal tracking-[-0.02em] text-[oklch(96%_0.005_90)]"
        style="--i: 1"
      >
        Work with me
      </h1>

      <p
        class="reveal font-satoshi-light m-0 mt-6 max-w-lg text-base leading-relaxed text-[oklch(72%_0.01_85)] md:text-lg"
        style="--i: 2"
      >
        I'm Anton Werschinin. Have a project in mind? I take on a select number
        of clients each year to ensure focused, high-quality collaboration.
      </p>

      <div
        class="reveal mt-12 md:mt-16"
        style="--i: 3"
      >
        <a
          class="email-link font-instrument-serif inline-flex max-w-full items-baseline gap-2 pb-1 text-[clamp(1.75rem,5vw,2.75rem)] leading-none tracking-[-0.02em] text-[oklch(96%_0.005_90)] no-underline"
          data-obfuscation="0"
          href="mailto:hello@qnt.one"
        >
          <span class="min-w-0 break-all">hello@qnt.one</span>
          <span
            class="arrow inline-flex shrink-0 translate-y-[0.08em] self-center"
            aria-hidden="true"
          >
            <svg
              class="size-[0.55em] md:size-[0.5em]"
              fill="none"
              height="24"
              viewBox="0 0 24 24"
              width="24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M6 18L18 6M18 6H9M18 6V15"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.25"
              ></path>
            </svg>
          </span>
        </a>
      </div>
    </div>
  </main>
</Layout>

<style>
  @media (prefers-reduced-motion: no-preference) {
    .reveal {
      opacity: 0;
      transform: translateY(0.875rem);
      animation: rise 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
      animation-delay: calc(var(--i) * 130ms + 120ms);
    }

    @keyframes rise {
      to {
        opacity: 1;
        transform: none;
      }
    }
  }

  .email-link {
    position: relative;
  }

  .email-link::before,
  .email-link::after {
    content: "";
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    height: 1px;
  }

  .email-link::before {
    background: oklch(96% 0.005 90 / 0.28);
  }

  .email-link::after {
    background: oklch(96% 0.005 90);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .email-link:hover::after,
  .email-link:focus-visible::after {
    transform: scaleX(1);
  }

  .email-link .arrow {
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .email-link:hover .arrow,
  .email-link:focus-visible .arrow {
    transform: translate(0.12em, -0.04em);
  }
</style>
