---
import Layout from "@/components/layout.astro";
import Footer from "@/components/footer.astro";

/* Selected work — re-enable when you have case studies to show
const projects = [
  {
    slug: "global-scale-infrastructure",
    title: "Global Scale Infrastructure",
    category: "Engineering",
    tile: "tile-infrastructure",
    year: "2024",
    delay: "0",
  },
  {
    slug: "premium-ecommerce-ux",
    title: "Premium E-commerce UX",
    category: "Design & Development",
    tile: "tile-ecommerce",
    year: "2024",
    delay: "100",
  },
  {
    slug: "intelligent-data-platform",
    title: "Intelligent Data Platform",
    category: "Engineering",
    tile: "tile-data-platform",
    year: "2023",
    delay: "200",
  },
  {
    slug: "brand-identity-system",
    title: "Brand Identity System",
    category: "Design",
    tile: "tile-brand-identity",
    year: "2023",
    delay: "300",
  },
];
*/

const antonLetters = ["A", "n", "t", "o", "n"];
const werLetters = ["W", "e", "r"];
const schininLetters = ["s", "c", "h", "i", "n", "i", "n"];

const indexLinks = [
  { label: "Services", href: "#services", external: false },
  { label: "Contact", href: "#contact", external: false },
  { label: "GitHub", href: "#github", external: false },
];

const services = [
  {
    number: "01",
    title: "Web Development",
    description:
      "Performance-driven applications built with modern stacks. From architecture to deployment, delivered with engineering rigour and attention to every millisecond.",
  },
  {
    number: "02",
    title: "Design",
    description:
      "Brand systems, interface design, and visual identity that communicate authority. Rooted in craft, built to endure, refined until nothing remains to remove.",
  },
  {
    number: "03",
    title: "Digital Transformation",
    description:
      "Strategic modernisation of legacy systems and digital workflows. Clear roadmaps, measurable outcomes, and technical consulting across the full stack.",
  },
];
---

<Layout
  description="Senior Designer & Engineer with a decade of experience building exceptional digital products."
  title="Anton Werschinin — Designer & Engineer"
>
  <main
    class="bg-black"
    id="main-content"
  >
    <!-- ─── HERO ─────────────────────────────────────────────── -->
    <section
      class="hero-section relative min-h-[100dvh] overflow-hidden"
      data-hero
    >
      <!-- Atmospheric layers (gradients + grain + spotlight) handled in CSS ::before/::after -->
      <div
        class="hero-spotlight"
        aria-hidden="true"
      >
      </div>
      <div
        class="hero-grid-lines"
        aria-hidden="true"
      >
      </div>

      <!-- Decorative diagonal rule -->
      <span
        class="hero-diagonal-rule"
        aria-hidden="true"
      ></span>

      <!-- Left vertical rail -->
      <span
        class="hero-vertical-rail hero-reveal"
        style="--reveal-delay: 250ms;"
        aria-hidden="true"
      >
        <span class="hero-rail-tick"></span>
        Senior Designer &amp; Engineer — Est. MMXV
        <span class="hero-rail-tick"></span>
      </span>

      <!-- Primary name composition -->
      <div class="hero-name-stage">
        <h1
          class="hero-h1 font-instrument-serif m-0"
          aria-label="Anton Werschinin"
        >
          <!-- Decorative outlined ghost (duplicate of primary name) -->
          <span
            class="hero-name-ghost hero-reveal"
            style="--reveal-delay: 600ms;"
            aria-hidden="true"
            >Anton</span
          >

          <!-- Primary: Anton (per-letter stagger) -->
          <span
            class="hero-name hero-name--primary"
            aria-hidden="true"
          >
            {
              antonLetters.map((ch, i) => (
                <span
                  class="hero-letter"
                  style={{
                    "--i": i,
                    "--reveal-delay": `${180 + i * 45}ms`,
                  }}
                >
                  {ch}
                </span>
              ))
            }
          </span>

          <!-- Secondary: Werschinin, italic, diagonal flow -->
          <span
            class="hero-name hero-name--secondary"
            aria-hidden="true"
          >
            <span class="hero-name-group hero-name-group--wer">
              {
                werLetters.map((ch, i) => (
                  <span
                    class="hero-letter hero-letter--sub hero-letter--italic"
                    style={{
                      "--i": i,
                      "--reveal-delay": `${520 + i * 40}ms`,
                    }}
                  >
                    {ch}
                  </span>
                ))
              }
            </span><span class="hero-name-group hero-name-group--schinin">
              {
                schininLetters.map((ch, i) => (
                  <span
                    class="hero-letter hero-letter--sub hero-letter--italic"
                    style={{
                      "--i": i,
                      "--reveal-delay": `${680 + i * 35}ms`,
                    }}
                  >
                    {ch}
                  </span>
                ))
              }
            </span>
          </span>
        </h1>

        <!-- Rule under secondary name, stretches into the right margin -->
        <span
          class="hero-name-rule hero-reveal"
          style="--reveal-delay: 900ms;"
          aria-hidden="true"
        ></span>
      </div>

      <!-- Centre-bottom tagline -->
      <p
        class="hero-tagline-block hero-reveal"
        style="--reveal-delay: 1000ms;"
      >
        <span class="hero-tagline-rule"></span>
        <span class="hero-tagline-text">
          Engineering precision, design intention,<br />
          and products that still make sense.
        </span>
      </p>

      <!-- Bottom-right index -->
      <nav
        class="hero-index hero-reveal"
        aria-label="Hero shortcuts"
        style="--reveal-delay: 1050ms;"
      >
        <span class="hero-index-label">Index</span>
        <ul class="hero-index-list">
          {
            indexLinks.map((link, i) => (
              <li>
                <a
                  class="hero-index-link"
                  href={link.href}
                  rel={link.external ? "noopener noreferrer" : undefined}
                  target={link.external ? "_blank" : undefined}
                >
                  <span class="hero-index-number">{`0${i + 1}`}</span>
                  <span class="hero-index-name">{link.label}</span>
                  <span
                    class="hero-index-arrow"
                    aria-hidden="true"
                  >
                    <svg
                      width="11"
                      height="11"
                      viewBox="0 0 11 11"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                      aria-hidden="true"
                    >
                      <path
                        d="M1.5 9.5L9.5 1.5M9.5 1.5H4M9.5 1.5V7"
                        stroke="currentColor"
                        stroke-width="1.25"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </section>

    {
      /*
    ─── SELECTED WORK (commented out — nothing to show yet; uncomment + restore `projects` in frontmatter)
    Use data-reveal-stagger on max-w-5xl, data-reveal-item + --reveal-index on header and tiles (see Core Services).
    <section
      class="scroll-mt-8 px-6 py-24 lg:scroll-mt-12 lg:py-36"
      id="selected-work"
    >
      <div class="mx-auto max-w-5xl" data-reveal-stagger>
        <div
          class="border-subtle mb-12 flex items-end justify-between border-b pb-8 lg:mb-16"
          data-reveal-item
          style={{ "--reveal-index": 0 }}
        >
          <div class="flex flex-col gap-3">
            <span class="section-label">Portfolio</span>
            <h2
              class="tone-primary font-instrument-serif m-0 text-3xl leading-none md:text-4xl lg:text-5xl"
            >
              Selected Work
            </h2>
          </div>
          <span class="tone-quiet font-satoshi-light hidden text-sm md:block"
            >2023 – 2024</span
          >
        </div>

        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:gap-6">
          {
            projects.map((project, i) => (
              <article
                class={`project-tile project-tile--static group relative overflow-hidden rounded-sm`}
                data-reveal-item
                style={{ "--reveal-index": i + 1 }}
                aria-labelledby={`tile-title-${project.slug}`}
              >
                <div
                  class={`${project.tile} aspect-[4/3] w-full lg:aspect-[3/2]`}
                  role="presentation"
                />

                <div
                  class="tile-overlay pointer-events-none absolute inset-0 transition-all duration-400"
                  style="background: linear-gradient(to top, oklch(0% 0 0 / 0.85) 0%, oklch(0% 0 0 / 0.35) 50%, oklch(0% 0 0 / 0.05) 100%);"
                />

                <div class="absolute inset-0 flex flex-col justify-between p-6 lg:p-8">
                  <div class="flex items-start justify-between gap-3">
                    <span class="section-label">{project.category}</span>
                    <div class="shrink-0 text-right">
                      <span class="tone-muted font-satoshi-light block text-xs tabular-nums">
                        {project.year}
                      </span>
                      <span class="tone-quiet font-satoshi-light mt-1 block text-[10px] uppercase tracking-wider">
                        Case study soon
                      </span>
                    </div>
                  </div>
                  <div class="flex items-end justify-between gap-4">
                    <h3
                      class="tone-primary font-instrument-serif m-0 max-w-[80%] text-xl leading-snug md:text-2xl lg:text-3xl"
                      id={`tile-title-${project.slug}`}
                    >
                      {project.title}
                    </h3>
                    <div
                      class="tile-arrow tone-muted"
                      aria-hidden="true"
                    >
                      <svg
                        width="20"
                        height="20"
                        viewBox="0 0 20 20"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <path
                          d="M5 15L15 5M15 5H7M15 5v8"
                          stroke="currentColor"
                          stroke-width="1.5"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        />
                      </svg>
                    </div>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>
    */
    }

    <!-- ─── CORE SERVICES ─────────────────────────────────────── -->
    <section
      class="border-subtle scroll-mt-8 border-t px-6 py-24 lg:scroll-mt-12 lg:py-36"
      id="services"
    >
      <div
        class="mx-auto max-w-5xl"
        data-reveal-stagger
      >
        <!-- Section header (reveals first in stagger) -->
        <div
          class="mb-16 flex flex-col gap-3 lg:mb-20"
          data-reveal-item
          style={{ "--reveal-index": 0 }}
        >
          <span class="section-label">What I do</span>
          <h2
            class="tone-primary font-instrument-serif m-0 text-3xl leading-none md:text-4xl lg:text-5xl"
          >
            Core Services
          </h2>
        </div>

        <!-- Services -->
        <div class="border-subtle divide-border-subtle flex flex-col divide-y">
          {
            services.map((service, i) => (
              <div
                class="service-row group grid grid-cols-1 gap-6 py-12 md:grid-cols-[120px_1fr_1fr] md:gap-8 md:py-10 lg:py-14"
                data-reveal-item
                style={{ "--reveal-index": i + 1 }}
              >
                <div class="service-number font-instrument-serif">
                  {service.number}
                </div>
                <h3 class="tone-primary font-satoshi-medium m-0 self-start text-xl md:text-2xl">
                  {service.title}
                </h3>
                <p class="tone-muted font-satoshi-light m-0 self-start text-base leading-relaxed md:text-lg">
                  {service.description}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ─── FOOTER ─────────────────────────────────────────────── -->
    <Footer />
  </main>
</Layout>
