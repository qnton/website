---
import Layout from "@/components/layout.astro";
import Footer from "@/components/footer.astro";
import { Image } from "astro:assets";

const projects = [
  {
    title: "Global Scale Infrastructure",
    category: "Engineering",
    tile: "tile-infrastructure",
    year: "2024",
    delay: "0",
  },
  {
    title: "Premium E-commerce UX",
    category: "Design & Development",
    tile: "tile-ecommerce",
    year: "2024",
    delay: "100",
  },
  {
    title: "Intelligent Data Platform",
    category: "Engineering",
    tile: "tile-data-platform",
    year: "2023",
    delay: "200",
  },
  {
    title: "Brand Identity System",
    category: "Design",
    tile: "tile-brand-identity",
    year: "2023",
    delay: "300",
  },
];

const services = [
  {
    number: "01",
    title: "Web Development",
    description:
      "Performance-driven applications built with modern stacks. From architecture to deployment, delivered with engineering rigour and attention to every millisecond.",
  },
  {
    number: "02",
    title: "Design",
    description:
      "Brand systems, interface design, and visual identity that communicate authority. Rooted in craft, built to endure, refined until nothing remains to remove.",
  },
  {
    number: "03",
    title: "Digital Transformation",
    description:
      "Strategic modernisation of legacy systems and digital workflows. Clear roadmaps, measurable outcomes, and technical consulting across the full stack.",
  },
];
---

<Layout
  description="Senior Designer & Engineer with a decade of experience building exceptional digital products."
  title="Anton Werschinin — Designer & Engineer"
>
  <main class="bg-black text-muted">
    <!-- ─── HERO ─────────────────────────────────────────────── -->
    <section
      class="relative flex min-h-[100dvh] flex-col items-center justify-center overflow-hidden px-6"
    >
      <!-- Background texture -->
      <div
        class="pointer-events-none absolute inset-0 opacity-30"
        style="background: radial-gradient(ellipse 80% 60% at 50% 0%, oklch(18% 0.01 60) 0%, transparent 70%);"
      ></div>

      <!-- Content -->
      <div
        class="relative z-10 flex w-full max-w-5xl flex-col items-start gap-8 lg:gap-12"
      >
        <!-- Profile + Name row -->
        <div class="flex items-center gap-6 md:gap-8 lg:gap-12">
          <Image
            alt="Anton Werschinin"
            class="animate-fade-right animate-once h-16 w-16 shrink-0 rounded-full border border-white/10 object-cover md:h-20 md:w-20 lg:h-24 lg:w-24"
            src="/images/pfp.jpg"
            width={512}
            height={512}
            loading="eager"
            fetchpriority="high"
          />
          <div class="flex flex-col gap-1">
            <span
              class="animate-fade animate-delay-75 animate-once section-label"
              >Available for projects</span
            >
            <div
              class="animate-fade-left animate-delay-150 animate-once h-px w-16 bg-[var(--c-border)]"
            >
            </div>
          </div>
        </div>

        <!-- Headline -->
        <div class="flex flex-col gap-5 lg:gap-8">
          <h1
            class="animate-fade-up animate-delay-100 animate-once font-instrument-serif m-0 text-5xl leading-none tracking-tight text-primary md:text-7xl lg:text-8xl xl:text-9xl"
          >
            Anton<br /><em class="text-dim not-italic">Werschinin</em>
          </h1>
          <p
            class="animate-fade-up animate-delay-200 animate-once font-satoshi-regular m-0 max-w-2xl text-base leading-snug tracking-normal text-muted md:text-lg lg:text-xl"
          >
            <span class="font-satoshi-medium text-primary"
              >Senior Designer &amp; Engineer</span
            >
            <span
              class="text-faint"
              aria-hidden="true"
            >
              ·
            </span>
            <span class="text-dim">10 years of craft</span>
          </p>
        </div>

        <!-- Ethos -->
        <p
          class="animate-fade-up animate-delay-300 animate-once font-satoshi-light m-0 max-w-xl text-base leading-relaxed text-dim md:text-lg"
        >
          Bridging engineering precision with design intention. I build products
          that perform at scale and feel inevitable in use.
        </p>
      </div>

      <!-- Scroll indicator -->
      <div
        class="animate-fade animate-delay-700 animate-once absolute bottom-10 left-1/2 flex -translate-x-1/2 flex-col items-center gap-2"
      >
        <span class="section-label">Scroll</span>
        <div class="scroll-indicator text-faint">
          <svg
            width="16"
            height="16"
            viewBox="0 0 16 16"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M8 3v10M4 9l4 4 4-4"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path>
          </svg>
        </div>
      </div>
    </section>

    <!-- ─── SELECTED WORK ──────────────────────────────────────── -->
    <section class="px-6 py-24 lg:py-36">
      <div class="mx-auto max-w-5xl">
        <!-- Section header -->
        <div
          class="on-sight:animate-fade mb-12 flex items-end justify-between border-b border-hairline pb-8 lg:mb-16"
        >
          <div class="flex flex-col gap-3">
            <span class="section-label">Portfolio</span>
            <h2
              class="font-instrument-serif m-0 text-3xl leading-none text-primary md:text-4xl lg:text-5xl"
            >
              Selected Work
            </h2>
          </div>
          <span
            class="font-satoshi-light text-faint hidden text-sm md:block"
            >2023 – 2024</span
          >
        </div>

        <!-- Project grid -->
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:gap-6">
          {
            projects.map((project) => (
              <div
                class={`on-sight:animate-fade-up project-tile group relative overflow-hidden rounded-sm`}
                style={`animation-delay: ${project.delay}ms;`}
              >
                <div
                  class={`${project.tile} aspect-[4/3] w-full lg:aspect-[3/2]`}
                />

                <div
                  class="tile-overlay pointer-events-none absolute inset-0 transition-all duration-400"
                  style="background: linear-gradient(to top, oklch(0% 0 0 / 0.85) 0%, oklch(0% 0 0 / 0.35) 50%, oklch(0% 0 0 / 0.05) 100%);"
                />

                <div class="absolute inset-0 flex flex-col justify-between p-6 lg:p-8">
                  <div class="flex items-start justify-between">
                    <span class="section-label">{project.category}</span>
                    <span class="font-satoshi-light text-faint text-xs">
                      {project.year}
                    </span>
                  </div>
                  <div class="flex items-end justify-between">
                    <h3 class="font-instrument-serif text-primary m-0 max-w-[80%] text-xl leading-snug md:text-2xl lg:text-3xl">
                      {project.title}
                    </h3>
                    <div class="tile-arrow text-dim">
                      <svg
                        width="20"
                        height="20"
                        viewBox="0 0 20 20"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <path
                          d="M5 15L15 5M15 5H7M15 5v8"
                          stroke="currentColor"
                          stroke-width="1.5"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        />
                      </svg>
                    </div>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ─── CORE SERVICES ─────────────────────────────────────── -->
    <section class="border-t border-hairline px-6 py-24 lg:py-36">
      <div class="mx-auto max-w-5xl">
        <!-- Section header -->
        <div class="on-sight:animate-fade mb-16 flex flex-col gap-3 lg:mb-20">
          <span class="section-label">What I do</span>
          <h2
            class="font-instrument-serif m-0 text-3xl leading-none text-primary md:text-4xl lg:text-5xl"
          >
            Core Services
          </h2>
        </div>

        <!-- Services -->
        <div class="flex flex-col divide-y divide-[var(--c-border)]">
          {
            services.map((service, i) => (
              <div
                class="on-sight:animate-fade-up group grid grid-cols-1 gap-6 py-10 md:grid-cols-[120px_1fr_1fr] md:gap-8 lg:py-14"
                style={`animation-delay: ${i * 100}ms;`}
              >
                <div class="service-number font-instrument-serif">
                  {service.number}
                </div>
                <h3 class="font-satoshi-medium text-primary m-0 self-start text-xl md:text-2xl">
                  {service.title}
                </h3>
                <p class="font-satoshi-light text-dim m-0 self-start text-base leading-relaxed md:text-lg">
                  {service.description}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ─── FOOTER ─────────────────────────────────────────────── -->
    <Footer class="on-sight:animate-fade" />
  </main>
</Layout>
