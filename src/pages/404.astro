---
import Layout from "@/components/layout.astro";
---

<Layout
  description="Page not found"
  noStructuredData
  robots="noindex, nofollow"
  title="qnt.one • Page not found"
>
  <main
    class="font-satoshi-regular flex min-h-[100dvh] flex-col items-center justify-center bg-black"
    id="main-content"
  >
    <section
      class="flex flex-col items-center justify-center gap-6 px-4 text-center"
    >
      <h1
        class="tone-primary font-instrument-serif animate-fade animate-once m-0 text-4xl tracking-wide md:text-5xl lg:text-7xl"
      >
        404
      </h1>
      <a
        class="font-satoshi-medium text-sm tracking-[0.12em] text-[oklch(62%_0_0)] uppercase no-underline transition-colors duration-150 ease-out hover:text-white"
        href="/"
      >
        Back to home
      </a>
    </section>
  </main>
</Layout>
