---
import Layout from "@/components/layout.astro";
import Footer from "@/components/footer.astro";

const title = "Impressum & Datenschutzerklärung — Anton Werschinin";
const description =
  "Impressum und Datenschutzerklärung gemäß TMG, DDG und DSGVO für qnt.one.";
---

<Layout
  description={description}
  lang="de"
  title={title}
>
  <main class="bg-black text-white">
    <article class="px-6 py-24 lg:py-36">
      <div class="mx-auto max-w-3xl">
        <header class="mb-16 border-b border-neutral-900 pb-12">
          <p class="section-label mb-4">Rechtliches</p>
          <h1
            class="font-instrument-serif m-0 text-4xl leading-tight text-neutral-50 md:text-5xl lg:text-6xl"
          >
            Impressum &amp; Datenschutz
          </h1>
          <p
            class="font-satoshi-light mt-6 max-w-2xl text-base leading-relaxed text-neutral-500"
          >
            Angaben gemäß §&nbsp;5 TMG, §&nbsp;55 RStV (soweit einschlägig)
            sowie Hinweise zur Datenverarbeitung nach der
            Datenschutz-Grundverordnung (DSGVO) und dem Bundesdatenschutzgesetz
            (BDSG).
          </p>
        </header>

        <div
          class="font-satoshi-light space-y-16 text-base leading-relaxed text-neutral-400"
        >
          <!-- Impressum -->
          <section
            class="space-y-6"
            aria-labelledby="impressum-heading"
          >
            <h2
              id="impressum-heading"
              class="font-instrument-serif m-0 text-2xl text-neutral-100 md:text-3xl"
            >
              Impressum
            </h2>

            <div class="space-y-4">
              <h3 class="font-satoshi-medium m-0 text-lg text-neutral-200">
                Diensteanbieter
              </h3>
              <address class="text-neutral-400 not-italic">
                <p class="m-0">Anton Werschinin</p>
                <p class="m-0">Hinterm Wall 28</p>
                <p class="m-0">49661 Cloppenburg</p>
                <p class="m-0">Deutschland</p>
              </address>
            </div>

            <div class="space-y-4">
              <h3 class="font-satoshi-medium m-0 text-lg text-neutral-200">
                Kontakt
              </h3>
              <p class="m-0">
                E-Mail:
                <a
                  class="text-neutral-300 underline decoration-neutral-700 underline-offset-4 transition-colors hover:text-white hover:decoration-neutral-500"
                  href="mailto:hello@qnt.one"
                  >hello@qnt.one</a
                >
              </p>
            </div>

            <div class="space-y-4">
              <h3 class="font-satoshi-medium m-0 text-lg text-neutral-200">
                Verantwortlich für den Inhalt nach §&nbsp;55 Abs.&nbsp;2 RStV
              </h3>
              <p class="m-0"> Anton Werschinin, Anschrift wie oben. </p>
            </div>

            <div class="space-y-4">
              <h3 class="font-satoshi-medium m-0 text-lg text-neutral-200">
                EU-Streitschlichtung
              </h3>
              <p class="m-0">
                Die Europäische Kommission stellt eine Plattform zur
                Online-Streitbeilegung (OS) bereit:
                <a
                  class="text-neutral-300 underline decoration-neutral-700 underline-offset-4 transition-colors hover:text-white hover:decoration-neutral-500"
                  href="https://ec.europa.eu/consumers/odr/"
                  rel="noopener noreferrer"
                  target="_blank"
                  >https://ec.europa.eu/consumers/odr/</a
                >. Unsere E-Mail-Adresse finden Sie oben im Impressum.
              </p>
            </div>

            <div class="space-y-4">
              <h3 class="font-satoshi-medium m-0 text-lg text-neutral-200">
                Verbraucherstreitbeilegung / Universalschlichtungsstelle
              </h3>
              <p class="m-0">
                Wir sind nicht verpflichtet und nicht bereit, an
                Streitbeilegungsverfahren vor einer
                Verbraucherschlichtungsstelle teilzunehmen.
              </p>
            </div>
          </section>

          <!-- Datenschutz -->
          <section
            class="space-y-6"
            aria-labelledby="datenschutz-heading"
          >
            <h2
              id="datenschutz-heading"
              class="font-instrument-serif m-0 text-2xl text-neutral-100 md:text-3xl"
            >
              Datenschutzerklärung
            </h2>

            <div class="space-y-4">
              <h3 class="font-satoshi-medium m-0 text-lg text-neutral-200">
                1. Verantwortlicher
              </h3>
              <p class="m-0">
                Verantwortlicher im Sinne der DSGVO ist Anton Werschinin,
                Hinterm Wall 28, 49661 Cloppenburg, Deutschland,
                <a
                  class="text-neutral-300 underline decoration-neutral-700 underline-offset-4 transition-colors hover:text-white hover:decoration-neutral-500"
                  href="mailto:hello@qnt.one"
                  >hello@qnt.one</a
                >.
              </p>
            </div>

            <div class="space-y-4">
              <h3 class="font-satoshi-medium m-0 text-lg text-neutral-200">
                2. Allgemeines zur Datenverarbeitung
              </h3>
              <p class="m-0">
                Wir verarbeiten personenbezogene Daten nur, soweit dies zur
                Bereitstellung einer funktionsfähigen Website, von Inhalten und
                Leistungen erforderlich ist, gesetzliche Verpflichtungen
                bestehen oder Sie eingewilligt haben.
              </p>
              <p class="m-0">
                Rechtsgrundlagen können insbesondere Art.&nbsp;6 Abs.&nbsp;1
                lit.&nbsp;a DSGVO (Einwilligung), lit.&nbsp;b DSGVO (Vertrag /
                vorvertragliche Maßnahmen), lit.&nbsp;c DSGVO (rechtliche
                Verpflichtung) und lit.&nbsp;f DSGVO (berechtigtes Interesse)
                sein.
              </p>
            </div>

            <div class="space-y-4">
              <h3 class="font-satoshi-medium m-0 text-lg text-neutral-200">
                3. Hosting und Aufruf der Website
              </h3>
              <p class="m-0">
                Diese Website wird bei einem Hosting-Anbieter betrieben. Beim
                Aufruf der Seiten werden durch den Host und ggf. durch uns
                technisch erforderliche Daten verarbeitet (z.&nbsp;B.
                IP-Adresse, Zeitpunkt der Anfrage, User-Agent), um die
                Auslieferung und Sicherheit der Website zu gewährleisten
                (berechtigtes Interesse gem. Art.&nbsp;6 Abs.&nbsp;1 lit.&nbsp;f
                DSGVO).
              </p>
              <p class="m-0">
                Sofern der Anbieter außerhalb des Europäischen Wirtschaftsraums
                (EWR) sitzt und kein Angemessenheitsbeschluss der EU-Kommission
                vorliegt, stellen wir — soweit erforderlich — geeignete
                Garantien sicher (z.&nbsp;B. EU-Standardvertragsklauseln) und
                informieren Sie gesondert, sobald Vertragsunterlagen öffentlich
                einsehbar sind.
              </p>
              <p class="m-0">
                Entsprechende Hinweise des Hosting-Anbieters (inkl.
                Auftragsverarbeitung) entnehmen Sie bitte dessen aktueller
                Datenschutzerklärung.
              </p>
            </div>

            <div class="space-y-4">
              <h3 class="font-satoshi-medium m-0 text-lg text-neutral-200">
                4. Kontakt per E-Mail
              </h3>
              <p class="m-0">
                Wenn Sie uns per E-Mail kontaktieren, verarbeiten wir die von
                Ihnen mitgeteilten Daten zur Bearbeitung der Anfrage und für den
                Fall von Anschlussfragen (Art.&nbsp;6 Abs.&nbsp;1 lit.&nbsp;b
                bzw. lit.&nbsp;f DSGVO). Die Daten werden gelöscht, sobald sie
                für die Erreichung des Zwecks nicht mehr erforderlich sind,
                sofern keine gesetzlichen Aufbewahrungspflichten entgegenstehen.
              </p>
            </div>

            <div class="space-y-4">
              <h3 class="font-satoshi-medium m-0 text-lg text-neutral-200">
                5. Cookies und lokale Speicherung
              </h3>
              <p class="m-0">
                Diese Website setzt keine Tracking-Cookies zu Werbe- oder
                Analysezwecken ein. Es können technisch notwendige Daten in
                Ihrem Browser verarbeitet werden (z.&nbsp;B. für die Darstellung
                oder Sicherheit), soweit dies ohne Einwilligung zulässig ist.
              </p>
            </div>

            <div class="space-y-4">
              <h3 class="font-satoshi-medium m-0 text-lg text-neutral-200">
                6. Externe Inhalte (z.&nbsp;B. Schriftarten)
              </h3>
              <p class="m-0">
                Zur Darstellung können Inhalte von Drittanbietern geladen werden
                (z.&nbsp;B. Schriftarten von Google Fonts). Dabei kann der
                Drittanbieter technische Informationen (u.&nbsp;a. IP-Adresse)
                erhalten. Rechtsgrundlage ist Art.&nbsp;6 Abs.&nbsp;1
                lit.&nbsp;f DSGVO (berechtigtes Interesse an einheitlicher,
                lesbarer Darstellung). Weitere Informationen finden Sie in der
                Datenschutzerklärung des jeweiligen Anbieters:
                <a
                  class="text-neutral-300 underline decoration-neutral-700 underline-offset-4 transition-colors hover:text-white hover:decoration-neutral-500"
                  href="https://policies.google.com/privacy?hl=de"
                  rel="noopener noreferrer"
                  target="_blank"
                  >Google (Datenschutzerklärung)</a
                >.
              </p>
            </div>

            <div class="space-y-4">
              <h3 class="font-satoshi-medium m-0 text-lg text-neutral-200">
                7. Ihre Rechte
              </h3>
              <p class="m-0">
                Sie haben — unter den gesetzlichen Voraussetzungen — Recht auf
                Auskunft (Art.&nbsp;15 DSGVO), Berichtigung (Art.&nbsp;16
                DSGVO), Löschung (Art.&nbsp;17 DSGVO), Einschränkung der
                Verarbeitung (Art.&nbsp;18 DSGVO), Datenübertragbarkeit
                (Art.&nbsp;20 DSGVO) sowie Widerspruch gegen die Verarbeitung
                (Art.&nbsp;21 DSGVO).
              </p>
              <p class="m-0">
                Sofern die Verarbeitung auf einer Einwilligung beruht, können
                Sie diese mit Wirkung für die Zukunft widerrufen (Art.&nbsp;7
                Abs.&nbsp;3 DSGVO).
              </p>
              <p class="m-0">
                Sie haben zudem das Recht, sich bei einer
                Datenschutzaufsichtsbehörde zu beschweren (Art.&nbsp;77 DSGVO).
                Zuständig ist u.&nbsp;a. die für Ihren Wohnsitz oder unseren
                Sitz zuständige Behörde. Eine Liste der Aufsichtsbehörden in der
                EU finden Sie unter
                <a
                  class="text-neutral-300 underline decoration-neutral-700 underline-offset-4 transition-colors hover:text-white hover:decoration-neutral-500"
                  href="https://www.bfdi.bund.de/DE/Service/Anschriften/anschriften_table.html"
                  rel="noopener noreferrer"
                  target="_blank"
                  >bfdi.bund.de</a
                >.
              </p>
            </div>

            <div class="space-y-4">
              <h3 class="font-satoshi-medium m-0 text-lg text-neutral-200">
                8. Speicherdauer
              </h3>
              <p class="m-0">
                Personenbezogene Daten werden gelöscht oder gesperrt, sobald der
                Zweck der Speicherung entfällt, es sei denn, gesetzliche
                Aufbewahrungsfristen stehen dem entgegen.
              </p>
            </div>
          </section>

          <!-- Haftung & Urheberrecht -->
          <section
            class="space-y-6"
            aria-labelledby="haftung-heading"
          >
            <h2
              id="haftung-heading"
              class="font-instrument-serif m-0 text-2xl text-neutral-100 md:text-3xl"
            >
              Haftungsausschluss &amp; Urheberrecht
            </h2>

            <div class="space-y-4">
              <h3 class="font-satoshi-medium m-0 text-lg text-neutral-200">
                Haftung für Inhalte
              </h3>
              <p class="m-0">
                Als Diensteanbieter sind wir gemäß §&nbsp;7 Abs.&nbsp;1 TMG für
                eigene Inhalte auf diesen Seiten nach den allgemeinen Gesetzen
                verantwortlich. Nach §§&nbsp;8 bis 10 TMG sind wir als
                Diensteanbieter jedoch nicht verpflichtet, übermittelte oder
                gespeicherte fremde Informationen zu überwachen oder nach
                Umständen zu forschen, die auf eine rechtswidrige Tätigkeit
                hinweisen.
              </p>
              <p class="m-0">
                Verpflichtungen zur Entfernung oder Sperrung der Nutzung von
                Informationen nach den allgemeinen Gesetzen bleiben hiervon
                unberührt. Eine diesbezügliche Haftung ist jedoch erst ab dem
                Zeitpunkt der Kenntnis einer konkreten Rechtsverletzung möglich.
                Bei Bekanntwerden entsprechender Rechtsverletzungen werden wir
                diese Inhalte umgehend entfernen.
              </p>
            </div>

            <div class="space-y-4">
              <h3 class="font-satoshi-medium m-0 text-lg text-neutral-200">
                Haftung für Links
              </h3>
              <p class="m-0">
                Unser Angebot enthält Links zu externen Websites Dritter, auf
                deren Inhalte wir keinen Einfluss haben. Deshalb können wir für
                diese fremden Inhalte auch keine Gewähr übernehmen. Für die
                Inhalte der verlinkten Seiten ist stets der jeweilige Anbieter
                oder Betreiber der Seiten verantwortlich. Die verlinkten Seiten
                wurden zum Zeitpunkt der Verlinkung auf mögliche Rechtsverstöße
                überprüft; rechtswidrige Inhalte waren zum Zeitpunkt der
                Verlinkung nicht erkennbar.
              </p>
              <p class="m-0">
                Eine permanente inhaltliche Kontrolle der verlinkten Seiten ist
                jedoch ohne konkrete Anhaltspunkte einer Rechtsverletzung nicht
                zumutbar. Bei Bekanntwerden von Rechtsverletzungen werden wir
                derartige Links umgehend entfernen.
              </p>
            </div>

            <div class="space-y-4">
              <h3 class="font-satoshi-medium m-0 text-lg text-neutral-200">
                Urheberrecht
              </h3>
              <p class="m-0">
                Die durch den Seitenbetreiber erstellten Inhalte und Werke auf
                diesen Seiten unterliegen dem deutschen Urheberrecht. Die
                Vervielfältigung, Bearbeitung, Verbreitung und jede Art der
                Verwertung außerhalb der Grenzen des Urheberrechts bedürfen der
                schriftlichen Zustimmung des jeweiligen Autors bzw. Erstellers.
                Downloads und Kopien dieser Seite sind nur für den privaten,
                nicht kommerziellen Gebrauch gestattet.
              </p>
              <p class="m-0">
                Soweit die Inhalte auf dieser Seite nicht vom Betreiber erstellt
                wurden, werden die Urheberrechte Dritter beachtet. Insbesondere
                werden Inhalte Dritter als solche gekennzeichnet. Sollten Sie
                trotzdem auf eine Urheberrechtsverletzung aufmerksam werden,
                bitten wir um einen entsprechenden Hinweis. Bei Bekanntwerden
                von Rechtsverletzungen werden wir derartige Inhalte umgehend
                entfernen.
              </p>
            </div>
          </section>

          <p class="m-0 text-sm text-neutral-600">Stand: April 2026</p>
        </div>

        <p class="mt-16">
          <a
            class="font-satoshi-regular text-sm text-neutral-500 transition-colors hover:text-neutral-300"
            href="/"
          >
            ← Zur Startseite
          </a>
        </p>
      </div>
    </article>

    <Footer class="on-sight:animate-fade" />
  </main>
</Layout>
