---
import Layout from "@/components/layout.astro";

const title = "Legal notice & privacy policy — qnt.one";
const description =
  "Legal notice (Imprint) and privacy information for qnt.one, including GDPR-related disclosures for visitors in the EU.";

const linkClass =
  "tone-primary underline decoration-[var(--color-border-strong)] underline-offset-4 transition-colors hover:decoration-[var(--color-text-muted)]";
---

<Layout
  description={description}
  title={title}
>
  <main id="main-content">
    <!-- Intro -->
    <section
      class="section"
      aria-labelledby="legal-page-title"
    >
      <div class="section__inner">
        <header class="section-head">
          <span class="section-head__label">Legal</span>
          <span class="section-head__meta">qnt.one · April 2026</span>
        </header>

        <h1
          class="section-title"
          id="legal-page-title"
        >
          Legal notice &amp; <em>privacy</em>
        </h1>

        <p
          class="tone-muted font-satoshi-light m-0 mt-6 max-w-2xl text-base leading-relaxed md:text-lg"
        >
          Information provided in accordance with the German Telemedia Act (TMG)
          and the Interstate Broadcasting Treaty (RStV), where applicable, and
          notes on processing personal data under the EU General Data Protection
          Regulation (GDPR) and the German Federal Data Protection Act (BDSG).
        </p>

        <nav
          class="hero-index mt-10 lg:mt-12"
          aria-label="Shortcuts"
        >
          <span class="hero-index-label">Navigate</span>
          <ul class="hero-index-list">
            <li>
              <a
                class="hero-index-link"
                href="/"
              >
                <span class="hero-index-number">00</span>
                <span class="hero-index-name">Home</span>
                <span
                  class="hero-index-arrow"
                  aria-hidden="true"
                >
                  <svg
                    width="11"
                    height="11"
                    viewBox="0 0 11 11"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                    aria-hidden="true"
                  >
                    <path
                      d="M1.5 9.5L9.5 1.5M9.5 1.5H4M9.5 1.5V7"
                      stroke="currentColor"
                      stroke-width="1.25"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    ></path>
                  </svg>
                </span>
              </a>
            </li>
          </ul>
        </nav>
      </div>
    </section>

    <!-- Imprint -->
    <section
      class="section"
      aria-labelledby="legal-notice-heading"
    >
      <div
        class="section__inner"
        data-reveal-stagger
      >
        <header class="section-head">
          <span class="section-head__label">Imprint</span>
          <span class="section-head__meta">TMG · RStV</span>
        </header>

        <h2
          class="service-row__title m-0 mb-10 max-w-[24ch]"
          id="legal-notice-heading"
        >
          Legal notice (Imprint)
        </h2>

        <div role="list">
          <article
            class="service-row"
            data-reveal-item
            role="listitem"
            style={{ "--reveal-index": 0 }}
          >
            <span
              class="service-row__num"
              aria-hidden="true"
              >01</span
            >
            <h3 class="service-row__title">Service provider</h3>
            <div class="service-row__body">
              <p class="m-0">
                The service provider within the meaning of the TMG is the
                operator of <span class="tone-primary">qnt.one</span>.
              </p>
            </div>
          </article>

          <article
            class="service-row"
            data-reveal-item
            role="listitem"
            style={{ "--reveal-index": 1 }}
          >
            <span
              class="service-row__num"
              aria-hidden="true"
              >02</span
            >
            <h3 class="service-row__title">Contact</h3>
            <p class="service-row__body m-0">
              Email:
              <a
                class={linkClass}
                href="mailto:hello@qnt.one"
                >hello@qnt.one</a
              >
            </p>
          </article>

          <article
            class="service-row"
            data-reveal-item
            role="listitem"
            style={{ "--reveal-index": 2 }}
          >
            <span
              class="service-row__num"
              aria-hidden="true"
              >03</span
            >
            <h3 class="service-row__title">
              Responsible for content (Sec. 55(2) RStV)
            </h3>
            <p class="service-row__body m-0">
              The operator of qnt.one, reachable at the contact details listed
              under “Contact” above.
            </p>
          </article>

          <article
            class="service-row"
            data-reveal-item
            role="listitem"
            style={{ "--reveal-index": 3 }}
          >
            <span
              class="service-row__num"
              aria-hidden="true"
              >04</span
            >
            <h3 class="service-row__title">EU dispute resolution</h3>
            <p class="service-row__body m-0">
              The European Commission provides a platform for online dispute
              resolution (ODR):
              <a
                class={linkClass}
                href="https://ec.europa.eu/consumers/odr/"
                rel="noopener noreferrer"
                target="_blank"
                >https://ec.europa.eu/consumers/odr/</a
              >. You can find our email address in this legal notice above.
            </p>
          </article>

          <article
            class="service-row"
            data-reveal-item
            role="listitem"
            style={{ "--reveal-index": 4 }}
          >
            <span
              class="service-row__num"
              aria-hidden="true"
              >05</span
            >
            <h3 class="service-row__title">Consumer dispute resolution</h3>
            <p class="service-row__body m-0">
              We are not obliged or willing to participate in dispute resolution
              proceedings before a consumer arbitration board.
            </p>
          </article>
        </div>
        <span
          class="rule-hair mt-4"
          aria-hidden="true"
        ></span>
      </div>
    </section>

    <!-- Privacy -->
    <section
      class="section"
      aria-labelledby="privacy-heading"
    >
      <div
        class="section__inner"
        data-reveal-stagger
      >
        <header class="section-head">
          <span class="section-head__label">Privacy</span>
          <span class="section-head__meta">GDPR · BDSG</span>
        </header>

        <h2
          class="service-row__title m-0 mb-10 max-w-[18ch]"
          id="privacy-heading"
        >
          Privacy policy
        </h2>

        <div role="list">
          <article
            class="service-row"
            data-reveal-item
            role="listitem"
            style={{ "--reveal-index": 0 }}
          >
            <span
              class="service-row__num"
              aria-hidden="true"
              >01</span
            >
            <h3 class="service-row__title">1. Controller</h3>
            <p class="service-row__body m-0">
              The controller within the meaning of the GDPR is the operator of
              qnt.one, reachable at
              <a
                class={linkClass}
                href="mailto:hello@qnt.one"
                >hello@qnt.one</a
              >.
            </p>
          </article>

          <article
            class="service-row"
            data-reveal-item
            role="listitem"
            style={{ "--reveal-index": 1 }}
          >
            <span
              class="service-row__num"
              aria-hidden="true"
              >02</span
            >
            <h3 class="service-row__title"
              >2. General information on processing</h3
            >
            <div class="service-row__body [&_p+p]:mt-4">
              <p class="m-0">
                We process personal data only to the extent necessary to provide
                a functional website and our content and services, to comply
                with legal obligations, or where you have given consent.
              </p>
              <p class="m-0">
                Legal bases may include Art. 6(1)(a) GDPR (consent), (b)
                (contract or pre-contractual steps), (c) (legal obligation), and
                (f) (legitimate interests), as applicable.
              </p>
            </div>
          </article>

          <article
            class="service-row"
            data-reveal-item
            role="listitem"
            style={{ "--reveal-index": 2 }}
          >
            <span
              class="service-row__num"
              aria-hidden="true"
              >03</span
            >
            <h3 class="service-row__title"
              >3. Hosting and visiting this website</h3
            >
            <div class="service-row__body [&_p+p]:mt-4">
              <p class="m-0">
                This website is operated on infrastructure provided by a hosting
                provider. When you access pages, the host and, where applicable,
                we process technically necessary data (e.g. IP address, time of
                the request, user agent) to deliver the site and maintain its
                security (legitimate interest under Art. 6(1)(f) GDPR).
              </p>
              <p class="m-0">
                If the provider is located outside the European Economic Area
                and no adequacy decision of the EU Commission applies, we will
                put appropriate safeguards in place where required (e.g. EU
                Standard Contractual Clauses) and provide further information
                when relevant documentation is publicly available.
              </p>
              <p class="m-0">
                Please refer to the hosting provider’s current privacy policy
                for details (including any data processing agreement).
              </p>
            </div>
          </article>

          <article
            class="service-row"
            data-reveal-item
            role="listitem"
            style={{ "--reveal-index": 3 }}
          >
            <span
              class="service-row__num"
              aria-hidden="true"
              >04</span
            >
            <h3 class="service-row__title">4. Contact by email</h3>
            <p class="service-row__body m-0">
              If you contact us by email, we process the data you provide to
              handle your request and any follow-up questions (Art. 6(1)(b) or
              (f) GDPR). Data is deleted once no longer needed for that purpose,
              unless statutory retention requirements apply.
            </p>
          </article>

          <article
            class="service-row"
            data-reveal-item
            role="listitem"
            style={{ "--reveal-index": 4 }}
          >
            <span
              class="service-row__num"
              aria-hidden="true"
              >05</span
            >
            <h3 class="service-row__title">5. Cookies and local storage</h3>
            <p class="service-row__body m-0">
              This website does not use tracking cookies for advertising or
              analytics. Technically necessary data may be processed in your
              browser (e.g. for display or security) where permitted without
              consent.
            </p>
          </article>

          <article
            class="service-row"
            data-reveal-item
            role="listitem"
            style={{ "--reveal-index": 5 }}
          >
            <span
              class="service-row__num"
              aria-hidden="true"
              >06</span
            >
            <h3 class="service-row__title"
              >6. Fonts and third-party resources</h3
            >
            <div class="service-row__body [&_p+p]:mt-4">
              <p class="m-0">
                Display and body fonts used on this website are self-hosted and
                served from the same origin as the pages. No font requests are
                sent to third-party font providers for that purpose.
              </p>
              <p class="m-0">
                If we embed other third-party content in the future (for example
                videos or maps), those providers may process technical data such
                as your IP address when that content is loaded. We will describe
                the legal basis and, where applicable, link to the provider’s
                privacy policy in an updated version of this notice.
              </p>
            </div>
          </article>

          <article
            class="service-row"
            data-reveal-item
            role="listitem"
            style={{ "--reveal-index": 6 }}
          >
            <span
              class="service-row__num"
              aria-hidden="true"
              >07</span
            >
            <h3 class="service-row__title">7. Your rights</h3>
            <div class="service-row__body [&_p+p]:mt-4">
              <p class="m-0">
                Where the legal requirements are met, you have the right to
                access (Art. 15 GDPR), rectification (Art. 16 GDPR), erasure
                (Art. 17 GDPR), restriction of processing (Art. 18 GDPR), data
                portability (Art. 20 GDPR), and to object to processing (Art. 21
                GDPR).
              </p>
              <p class="m-0">
                Where processing is based on consent, you may withdraw consent
                with effect for the future (Art. 7(3) GDPR).
              </p>
              <p class="m-0">
                You also have the right to lodge a complaint with a supervisory
                authority (Art. 77 GDPR), in particular in the member state of
                your habitual residence or our place of establishment. A list of
                authorities in Germany is available at
                <a
                  class={linkClass}
                  href="https://www.bfdi.bund.de/EN/Service/Anschriften/anschriften_table.html"
                  rel="noopener noreferrer"
                  target="_blank"
                  >bfdi.bund.de</a
                >.
              </p>
            </div>
          </article>

          <article
            class="service-row"
            data-reveal-item
            role="listitem"
            style={{ "--reveal-index": 7 }}
          >
            <span
              class="service-row__num"
              aria-hidden="true"
              >08</span
            >
            <h3 class="service-row__title">8. Storage period</h3>
            <p class="service-row__body m-0">
              Personal data is deleted or blocked once the purpose of storage no
              longer applies, unless statutory retention periods require
              otherwise.
            </p>
          </article>
        </div>
        <span
          class="rule-hair mt-4"
          aria-hidden="true"
        ></span>
      </div>
    </section>

    <!-- Liability -->
    <section
      class="section"
      aria-labelledby="liability-heading"
    >
      <div
        class="section__inner"
        data-reveal-stagger
      >
        <header class="section-head">
          <span class="section-head__label">Liability</span>
          <span class="section-head__meta">Content · Copyright</span>
        </header>

        <h2
          class="service-row__title m-0 mb-10 max-w-[22ch]"
          id="liability-heading"
        >
          Liability &amp; copyright
        </h2>

        <div role="list">
          <article
            class="service-row"
            data-reveal-item
            role="listitem"
            style={{ "--reveal-index": 0 }}
          >
            <span
              class="service-row__num"
              aria-hidden="true"
              >01</span
            >
            <h3 class="service-row__title">Liability for content</h3>
            <div class="service-row__body [&_p+p]:mt-4">
              <p class="m-0">
                As a service provider, we are responsible for our own content on
                these pages under general law in accordance with Sec. 7(1) TMG.
                Under Secs. 8 to 10 TMG, however, we are not obliged to monitor
                transmitted or stored third-party information or to investigate
                circumstances indicating illegal activity.
              </p>
              <p class="m-0">
                Obligations to remove or block the use of information under
                general law remain unaffected. Liability in this regard is only
                possible from the time we become aware of a specific legal
                violation. Upon notification of such violations, we will remove
                the content immediately.
              </p>
            </div>
          </article>

          <article
            class="service-row"
            data-reveal-item
            role="listitem"
            style={{ "--reveal-index": 1 }}
          >
            <span
              class="service-row__num"
              aria-hidden="true"
              >02</span
            >
            <h3 class="service-row__title">Liability for links</h3>
            <div class="service-row__body [&_p+p]:mt-4">
              <p class="m-0">
                Our site contains links to external third-party websites over
                whose content we have no control. We cannot assume any liability
                for that external content. The respective provider or operator
                of the linked pages is always responsible for their content. The
                linked pages were checked for possible legal violations at the
                time the link was created; no unlawful content was identifiable
                at that time.
              </p>
              <p class="m-0">
                Permanent monitoring of linked pages without concrete evidence
                of a violation is not reasonable. If we become aware of legal
                violations, we will remove such links immediately.
              </p>
            </div>
          </article>

          <article
            class="service-row"
            data-reveal-item
            role="listitem"
            style={{ "--reveal-index": 2 }}
          >
            <span
              class="service-row__num"
              aria-hidden="true"
              >03</span
            >
            <h3 class="service-row__title">Copyright</h3>
            <div class="service-row__body [&_p+p]:mt-4">
              <p class="m-0">
                Content and works on these pages created by the site operator
                are subject to German copyright law. Duplication, editing,
                distribution, and any kind of exploitation outside the limits of
                copyright require the written consent of the respective author
                or creator. Downloads and copies of this site are permitted only
                for private, non-commercial use.
              </p>
              <p class="m-0">
                Where content on this site was not created by the operator, the
                copyrights of third parties are respected. Third-party content
                is marked as such. Should you nevertheless become aware of a
                copyright infringement, please notify us. Upon notification of
                violations, we will remove such content immediately.
              </p>
            </div>
          </article>
        </div>
      </div>
    </section>
  </main>
</Layout>
